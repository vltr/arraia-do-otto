# Frontend build-time vars (Vite). Copy to .env (gitignored) for local builds.
# The Turnstile SITE key is public (safe in client code); the SECRET key is not
# and lives in .dev.vars / Pages secrets instead.

# Turnstile site key. Leave unset locally to render the form without the widget.
# VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
